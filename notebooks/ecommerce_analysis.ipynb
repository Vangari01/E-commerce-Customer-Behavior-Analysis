 import pandas as pd
df=pd.read_csv('ecommerce_dataset_+1m.csv')
 ##Exploratory Data Analysis
df.head()
df.info()
df.describe(include='all')
df.isnull().sum().sort_values(ascending=False)
df.duplicated().sum()
##Data Cleaning
df['return_reason'] = df['return_reason'].fillna('No Return')
df['coupon_code'] = df['coupon_code'].fillna('No Coupon')
df['customer_feedback'] = df['customer_feedback'].fillna('No Feedback')
df.isnull().sum().sort_values(ascending=False)
df['customer_feedback'].value_counts()
df[['coupon_code','customer_feedback','return_reason']].head(10)
df['order_date'] = pd.to_datetime(df['order_date'])
df['unit_price_usd'] = df['unit_price_usd'].astype(float)
print(df['order_date'].dtype)
##Feature Engeneering
df['order_frequency'] = df.groupby('order_id')['order_id'].transform('count')
##Investigating if orders are duplicates or is it synthetic data same ID repeated
df[df['order_frequency'] > 1].sort_values('order_id')
df[df.duplicated(subset=['order_id'], keep=False)]
df[df['order_id'] == 'ORD-DIUOV']
df[df.duplicated()]
df['total_revenue'] = df['unit_price_usd'] * df['quantity']
from sqlalchemy import create_engine

username = 'postgres'
