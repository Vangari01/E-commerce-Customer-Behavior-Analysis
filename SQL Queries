select * from customer limit 20;
--##what is the total revenue generated by male vs female
SELECT gender,SUM(total_price_usd) AS revenue 
FROM customer
GROUP BY gender;
--##which customers used coupons but still spent more than average purchase amount
select customer_id,total_price_usd from customer 
where coupon_used='Yes' and total_price_usd>=
(select AVG(total_price_usd) from customer);
--##Top products with the highest review rating, Quality (rating),Popularity(orders)
--,Business value(revenue),this is important because products with highest rating can be sold at prmium price
select distinct product_name, product_rating_avg from customer; 
SELECT product_name,ROUND(AVG(product_rating_avg)::numeric,2) AS avg_rating,
COUNT(*) AS total_orders,SUM(total_price_usd) AS revenue
FROM customer
GROUP BY product_name
ORDER BY avg_rating DESC, revenue DESC
LIMIT 10;
--##Compare average purchase amounts between shippping methods
select shipping_method , round(AVG(total_price_usd)::numeric,2) as Avg_purchase_amount
from customer
group by shipping_method
order by Avg_purchase_amount desc;
--##Compare average spend and total revenue between among source of cacmpaign
select campaign_source, count(customer_id)as total_customers,
ROUND(avg(total_price_usd)::numeric,2)as avg_spend,
ROUND(SUM(total_price_usd)::numeric,2)as total_revenue
from customer
group by campaign_source
order by total_revenue,avg_spend asc;
--## count of each segment
select customer_segment,count(*) as Number_of_customers from customer
group by  customer_segment;
--##What are the rop 3 products within each category 
with item_counts as(
select category, product_name,count(customer_id)as total_orders, 
Row_Number() over (partition by category order by Count(customer_id)DESC)as item_rank
from customer
group by category, product_name)
select 	item_rank, category, product_name, total_orders from item_counts
where item_rank <=3;
--##age group buying pattern
SELECT 
    CASE 
        WHEN age BETWEEN 18 AND 25 THEN '18-25'
        WHEN age BETWEEN 26 AND 35 THEN '26-35'
        WHEN age BETWEEN 36 AND 45 THEN '36-45'
        WHEN age BETWEEN 46 AND 60 THEN '46-60'ELSE '60+'
END AS age_group,
COUNT(CASE WHEN is_weekend = 'Yes' THEN 1 END) AS weekend_orders,
COUNT(CASE WHEN is_weekend = 'No' THEN 1 END) AS weekday_orders
FROM customer
WHERE order_status = 'Completed'
GROUP BY age_group
ORDER BY age_group;
--##revenue contribution of each age group 
select  CASE 
        WHEN age BETWEEN 18 AND 25 THEN '18-25'
        WHEN age BETWEEN 26 AND 35 THEN '26-35'
        WHEN age BETWEEN 36 AND 45 THEN '36-45'
        WHEN age BETWEEN 46 AND 60 THEN '46-60'ELSE '60+'END AS age_group,
		ROUND(sum(total_price_usd)::numeric,2) as total_revenue
		from customer
		group by age_group
		order by total_revenue desc;

